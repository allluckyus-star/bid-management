{
  "name": "job-bid-history-manager",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run build:shared && npm run dev -w @jbhm/web",
    "build:web": "npm run build:shared && npm run build -w @jbhm/web",
    "build:shared": "npm run build -w @jbhm/shared",
    "generate:icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "sharp": "^0.33.5"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
