{
  "manifest_version": 3,
  "name": "Job Bid History Capture",
  "version": "0.7.3",
  "description": "Capture job pages, optimize resumes via ChatGPT, and sync to your team dashboard.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "notifications", "downloads"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Bid Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "generate-chatgpt-prompt": {
      "suggested_key": {
        "default": "Alt+W"
      },
      "description": "Build prompt from server and send to ChatGPT (ChatGPT tab only)"
    },
    "download-resume-export": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Download latest optimized resume DOCX"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://www.chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["chatgpt-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
