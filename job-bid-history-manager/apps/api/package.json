{
  "name": "@jbhm/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 5123",
    "dev:lan": "python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 5123",
    "start": "python -m uvicorn app.main:app --host 127.0.0.1 --port 5123",
    "start:lan": "python -m uvicorn app.main:app --host 0.0.0.0 --port 5123",
    "seed": "python -m scripts.seed_sample",
    "seed:reset": "python -m scripts.seed_sample --reset",
    "demo:once": "python -m scripts.demo_tick --once",
    "demo:tick": "python -m scripts.demo_tick --interval 60"
  }
}
