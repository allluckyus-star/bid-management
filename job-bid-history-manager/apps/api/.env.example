# Copy to apps/api/.env (never commit real keys)

# Groq — fast cloud LLM (free tier). Tried first when set.
JBHM_GROQ_API_KEY=gsk_your_key_here
JBHM_GROQ_MODEL=llama-3.3-70b-versatile

# Local Ollama — fallback if Groq fails or key is empty
# JBHM_OLLAMA_BASE_URL=http://127.0.0.1:11434
# JBHM_OLLAMA_MODEL=llama3.2

# Force heuristic-only extraction (no LLM)
# JBHM_USE_MOCK_EXTRACTION=true
