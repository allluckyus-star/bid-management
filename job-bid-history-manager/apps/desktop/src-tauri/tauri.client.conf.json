{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Job Bid History Manager (Client)",
  "version": "0.1.0",
  "identifier": "com.jbhm.desktop.client",
  "build": {
    "beforeDevCommand": "npm run dev:client",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:client",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Job Bid History Manager (Client)",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
