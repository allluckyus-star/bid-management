{
  "name": "@jbhm/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vite:client": "vite --mode client",
    "dev:lan": "vite --mode lan --host 0.0.0.0",
    "prebuild": "npm run generate:icons --prefix ../..",
    "build": "tsc -b && vite build",
    "build:client": "npm run generate:icons --prefix ../.. && tsc -b && vite build --mode client",
    "preview": "vite preview",
    "tauri": "node ../../scripts/run-with-cargo.mjs tauri",
    "tauri:dev": "node ../../scripts/run-with-cargo.mjs tauri dev",
    "tauri:build": "node ../../scripts/run-with-cargo.mjs tauri build",
    "dev:client": "npm run build:client && node ../../scripts/run-gateway-dev.mjs",
    "bundle:client": "node ../../scripts/bundle-client.mjs"
  },
  "dependencies": {
    "@jbhm/shared": "*",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-table": "^8.20.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/cli": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^6.0.6"
  }
}
