# Supabase (Project Settings → API)
# https://supabase.com/dashboard/project/_/settings/api
# Base project URL only — do NOT append /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only — never prefix with NEXT_PUBLIC_
# Used in Phase 3+ Route Handlers (not in the browser or Chrome extension)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq: Groq hosts the LLM API; Vercel only runs your Next.js app which CALLS Groq.
# Set these in Vercel → Project → Environment Variables (Production + Preview).
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Max characters sent to Groq per capture (default 10000).
GROQ_MAX_CAPTURE_CHARS=10000

# Vercel Hobby CPU: keep false in production so /api/capture/job uses fast heuristic only.
# Set true only when you need synchronous AI extraction on capture.
SYNC_CAPTURE_EXTRACTION=false

# Skips Supabase realtime subscribe/broadcast during capture (saves CPU; dashboard refreshes on load).
ENABLE_REALTIME_INVALIDATION=false

# Web dashboard: disable background polling; use manual Refresh (recommended on Hobby).
NEXT_PUBLIC_FREE_TIER_SAFE_MODE=true
# Max characters sent to Groq per capture (default 10000). Extension caps at 30000 before upload.
GROQ_MAX_CAPTURE_CHARS=10000

# Vercel Hobby CPU: keep these OFF in production unless debugging.
# SYNC_CAPTURE_EXTRACTION=true  → run Groq inside POST /api/capture/job (slow, high CPU)
# ENABLE_REALTIME_INVALIDATION=true → Supabase realtime subscribe per capture (~5s)
SYNC_CAPTURE_EXTRACTION=
ENABLE_REALTIME_INVALIDATION=

# Phase 2+ extension capture tokens (hashing)
APP_CAPTURE_TOKEN_SECRET=generate-a-long-random-string

# Team join approval emails (Resend)


RESEND_API_KEY=re_WZFkAqf2_63i8HD6HBhmmM9NyZemUm9Su
RESEND_FROM_EMAIL=Job Bid History <onboarding@resend.dev>
# APP_BASE_URL=https://bid-management-8q62v5m4k-ethan-s-projects-1231.vercel.app/
APP_BASE_URL= http://localhost:3000
TEAM_JOIN_TOKEN_SECRET=team-secret-token